{
    "name": "Articles Sharp",
    "description": "Adds sharp commands to the context menu for image file conversions.",
    "version": "0.0.1",
    "extension_version": "0.0.1",
    "author": "Articles Media",
    "license": "MIT",
    "commands": [
        {
            "command": "convert_to_webp.js",
            "title": "Convert to WebP",
            "file_extensions": [
                "png",
                "jpg",
                "jpeg"
            ]
        },
        {
            "command": "convert_image.js",
            "title": "Convert Image",
            "file_extensions": [
                "png",
                "jpg",
                "jpeg",
                "webp",
                "ico"
            ]
        }
    ]
}